{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node scripts/build-projects.mjs && node scripts/minify-assets.mjs",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/project-01.html", "destination": "/riot-mmo-cinematic", "permanent": true },
    { "source": "/project-01",      "destination": "/riot-mmo-cinematic", "permanent": true },
    { "source": "/project-02.html", "destination": "/la-papiche-bistrot", "permanent": true },
    { "source": "/project-02",      "destination": "/la-papiche-bistrot", "permanent": true },
    { "source": "/project-03.html", "destination": "/dr-sophie-marchand", "permanent": true },
    { "source": "/project-03",      "destination": "/dr-sophie-marchand", "permanent": true },
    {
      "source": "/project.html",
      "has": [{ "type": "query", "key": "id", "value": "01" }],
      "destination": "/riot-mmo-cinematic",
      "permanent": true
    },
    {
      "source": "/project.html",
      "has": [{ "type": "query", "key": "id", "value": "02" }],
      "destination": "/la-papiche-bistrot",
      "permanent": true
    },
    {
      "source": "/project.html",
      "has": [{ "type": "query", "key": "id", "value": "03" }],
      "destination": "/dr-sophie-marchand",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), accelerometer=(), gyroscope=(), interest-cohort=()"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.bunny.net; font-src 'self' data: https://fonts.bunny.net; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com https://*.r2.dev; frame-src 'self' https://calendly.com; form-action 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
